theme = mocha.conf
font-family = "JetBrains Mono Light"
shell-integration-features = no-cursor

custom-shader = shaders/cursor_sweep.glsl

font-size = 14

gtk-wide-tabs = false

cursor-style = block
cursor-style-blink = true

window-padding-x = 5
window-padding-y = 5
window-vsync = true

clipboard-write = allow
clipboard-read = allow
shell-integration = zsh

# background-blur = true
# background-opacity = 0.7
# background-blur-radius = 4

# keybinds
macos-option-as-alt = true

keybind = cmd+t=new_tab
keybind = cmd+shift+right_bracket=next_tab
keybind = cmd+shift+left_bracket=previous_tab
keybind = cmd+shift+alt+right_bracket=move_tab:+1
keybind = cmd+shift+alt+left_bracket=move_tab:-1

keybind = cmd+d=new_split:down
keybind = cmd+shift+d=new_split:right

keybind = ctrl+h=goto_split:left
keybind = ctrl+l=goto_split:right
keybind = ctrl+k=goto_split:up
keybind = ctrl+j=goto_split:down

keybind = cmd+shift+h=resize_split:left,15
keybind = cmd+shift+l=resize_split:right,15
keybind = cmd+shift+k=resize_split:up,15
keybind = cmd+shift+j=resize_split:down,15

keybind = cmd+e=equalize_splits

keybind = cmd+x=close_surface
